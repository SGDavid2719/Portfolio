rd-img-top\" />\r\n                                        </div>\r\n                                        <div className=\"card-body\">\r\n                                            <h3>{name}</h3>\r\n                                            <p>{description}</p>\r\n                                            <a href=\"#\">Know more</a>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                            ))\r\n                        }\r\n                    </div>\r\n                    <div className=\"text-center mt-4\">\r\n                        <Link href=\"/portfolio\">\r\n                            <a className=\"btn btn-outline-light\">More porjects</a>\r\n                        </Link>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </Layout>\r\n)\r\nexport default Index;"]},"metadata":{},"sourceType":"module"}